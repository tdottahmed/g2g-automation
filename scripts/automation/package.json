{
  "name": "g2g-automation-runner",
  "version": "1.0.0",
  "description": "Local Playwright runner for g2g.com offer automation",
  "type": "module",
  "main": "runner.js",
  "scripts": {
    "start": "node runner.js",
    "watch": "node runner.js --watch",
    "status": "node runner.js --status",
    "delete": "node delete-offers.js",
    "install:browsers": "npx playwright install chromium",
    "postinstall": "npx playwright install chromium"
  },
  "dependencies": {
    "dotenv": "^17.0.0",
    "playwright": "^1.55.0"
  }
}
