# URL of the live Laravel application (no trailing slash)
LARAVEL_API_URL=https://your-laravel-app.com

# Must match API_AUTOMATION_KEY in the Laravel .env
API_KEY=

# Local directory where g2g.com session cookie files are stored.
# Files are named {email-prefix}.json (e.g. developertanbir1.json)
COOKIES_DIR=./cookies

# Playwright settings
HEADLESS=true
SLOW_MO=120

# Base URL of g2g.com (rarely needs changing)
G2G_BASE_URL=https://www.g2g.com

# Watch mode: how often (in seconds) to poll for new templates
# Only used when running: node runner.js --watch
WATCH_INTERVAL_SECONDS=60
